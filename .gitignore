build/
out/
dist/
exports/
*.epub
*.db
*.db-shm
*.db-wal
*.txt
*.log
plans/

# Ignore IDE and editor files
.vs/
*.user
compile_commands.json
.vscode/

# Ignore WinUI / .NET GUI artifacts
src/gui/NovelDownloaderGui/bin/
src/gui/NovelDownloaderGui/obj/
