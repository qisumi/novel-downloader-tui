<Page
    x:Class="NovelDownloaderGui.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <ScrollViewer>
        <Grid
            Padding="24,20,24,24"
            RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="设置" />
                <TextBlock
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="这里决定 GUI 使用哪个书源，以及数据库、插件与导出目录。" />
            </StackPanel>

            <InfoBar
                x:Name="SettingsStatusBar"
                Grid.Row="1"
                IsOpen="False"
                Severity="Informational" />

            <Border
                Grid.Row="2"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBox x:Name="RepositoryRootTextBox" Header="仓库根目录" />
                    <TextBox x:Name="PluginDirectoryTextBox" Header="插件目录" />
                    <TextBox x:Name="DatabasePathTextBox" Header="数据库路径" />
                    <TextBox x:Name="OutputDirectoryTextBox" Header="导出目录" />
                    <ComboBox
                        x:Name="SourceComboBox"
                        DisplayMemberPath="Name"
                        Header="当前书源"
                        SelectedValuePath="Id" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Click="OnReloadSourcesClicked" Content="重新读取书源" />
                        <Button Click="OnSaveClicked" Content="保存设置" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
