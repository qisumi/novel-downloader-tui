{
  "version": 6,
  "configurePresets": [
    {
      "name": "msvc-base",
      "hidden": true,
      "generator": "Visual Studio 18 2026",
      "architecture": {
        "value": "x64"
      },
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "NOVEL_ENABLE_WEBVIEW_GUI": "ON",
        "VCPKG_TARGET_TRIPLET": "x64-windows"
      }
    },
    {
      "name": "windows-x64-debug-msvc",
      "displayName": "Windows x64 Debug (MSVC)",
      "inherits": "msvc-base",
      "binaryDir": "${sourceDir}/build/debug-msvc"
    },
    {
      "name": "windows-x64-release-msvc",
      "displayName": "Windows x64 Release (MSVC)",
      "inherits": "msvc-base",
      "binaryDir": "${sourceDir}/build/release-msvc"
    },
    {
      "name": "windows-x64-release-static-msvc",
      "displayName": "Windows x64 Release Static (MSVC)",
      "inherits": "msvc-base",
      "binaryDir": "${sourceDir}/build/release-static-msvc",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-x64-debug-msvc",
      "configurePreset": "windows-x64-debug-msvc",
      "configuration": "Debug"
    },
    {
      "name": "windows-x64-release-msvc",
      "configurePreset": "windows-x64-release-msvc",
      "configuration": "Release"
    },
    {
      "name": "windows-x64-release-static-msvc",
      "configurePreset": "windows-x64-release-static-msvc",
      "configuration": "Release"
    }
  ]
}
