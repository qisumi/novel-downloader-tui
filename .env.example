# 小说下载工具 - .env 示例
# 用法：
#   1. 复制本文件为 .env
#   2. 按需填写插件所需配置
#   3. 宿主启动时会优先读取系统环境变量，其次读取 .env
#
# 配置优先级：
#   命令行参数 > 系统环境变量 > .env 文件

# 插件配置
# fanqie.lua 需要 FANQIE_APIKEY
FANQIE_APIKEY=your_fanqie_api_key

# qimao.lua 需要 QIMAO_APIKEY，如暂时不用可保留注释
# QIMAO_APIKEY=your_qimao_api_key

# 宿主通用配置
NOVEL_DB=novel.db
NOVEL_EPUB_DIR=exports
NOVEL_PLUGIN_DIR=plugins
NOVEL_SOURCE=fanqie
